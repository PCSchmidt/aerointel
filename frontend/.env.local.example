# AeroIntel frontend environment variables
# Copy this to .env.local and fill in the values for your environment.

# Backend base URL (no trailing slash)
# Local dev:   http://localhost:8000
# Fly.io:      https://aerointel-backend.fly.dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend WebSocket URL (no trailing slash)
# Local dev:   ws://localhost:8000
# Fly.io:      wss://aerointel-backend.fly.dev
NEXT_PUBLIC_WS_URL=ws://localhost:8000
