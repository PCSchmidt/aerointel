# AeroIntel environment variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for LLM features (NL query, situation summary, anomaly explanation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenSky OAuth client credentials for higher rate limits
# OpenSky now uses OAuth2 client credentials, not basic auth.
# Create an API client in your OpenSky account and paste the values here.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Legacy aliases still supported by this app for backward compatibility.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
