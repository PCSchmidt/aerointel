# AeroIntel environment variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for LLM features (NL query, situation summary, anomaly explanation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenSky Network credentials for higher rate limits
# Anonymous rate limit: 100 requests/day (~1 per 15 min)
# Authenticated: significantly higher limits (free registration at opensky-network.org)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
